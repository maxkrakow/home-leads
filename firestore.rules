rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to read and write their own pending subscriptions
    match /pendingSubscriptions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read the Counties collection
    match /Counties/{documentId} {
      allow read: if request.auth != null;
    }
    
    // Leads: public create (landing page form), open read for /leads admin page
    // (gated client-side by access code only — anyone with project id can query)
    match /leads/{leadId} {
      allow read: if true;
      allow create: if true;
    }
    
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}